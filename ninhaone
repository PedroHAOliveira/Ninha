            <div class="combo-card">
                <div>
                    <h3 class="combo-name">Combo Shake & Pão de Queijo</h3>
                    <div class="combo-desc-wrapper">
                        <!-- Ícone: Copo de Milkshake com Chantilly e Pão de Queijo -->
                        <svg class="combo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22 L16 42 C16 44 18 44 20 44 L28 44 C30 44 32 44 32 42 L36 22"></path>
                            <path d="M10 22 H38"></path>
                            <path d="M14 22 C12 16 18 16 20 12 C20 6 28 6 28 12 C30 16 36 16 34 22"></path>
                            <path d="M24 8 L28 2"></path>
                            <circle cx="40" cy="34" r="7"></circle>
                            <path d="M38 32 C39 34 41 34 42 32"></path>
                            <circle cx="42" cy="36" r="1" fill="currentColor"></circle>
                            <circle cx="39" cy="37" r="1" fill="currentColor"></circle>
                        </svg>

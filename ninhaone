<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cardápio de Combos</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* 🎨 GUIA DE CORES APLICADO */
        :root {
            --fundo-creme: #FFF4E6;
            --texto-marrom: #7A4A2E;
            --preco-antigo-turquesa: #7ACCC9;
            --preco-novo-laranja: #FF7A5A;
            --detalhes-amarelo: #FFC83D;
        }

        body {
            background-color: var(--fundo-creme);
            color: var(--texto-marrom);
            font-family: 'Montserrat', sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .menu-container {
            max-width: 800px;
            width: 100%;
            background-color: var(--fundo-creme);
            /* Borda sutil amarela para dar um charme de cardápio físico */
            border: 8px solid var(--detalhes-amarelo);
            border-radius: 24px;
            padding: 30px 20px;
            box-shadow: 0 10px 30px rgba(122, 74, 46, 0.1);
        }

        .main-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 800;
            margin-top: 0;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--texto-marrom);
            position: relative;
        }

        .main-title::after {
            content: '';
            display: block;
            width: 80px;
            height: 4px;
            background-color: var(--preco-novo-laranja);
            margin: 10px auto 0;
            border-radius: 2px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 40px 0 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--texto-marrom);
            border-bottom: 2px dashed var(--detalhes-amarelo);
            padding-bottom: 10px;
        }

        .combos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .combo-card {
            background-color: var(--fundo-creme);
            border: 2px solid var(--detalhes-amarelo);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s ease;
            /* Sombra turquesa suave para dar profundidade de forma elegante */
            box-shadow: 4px 4px 0px var(--preco-antigo-turquesa);
        }

        .combo-card:hover {
            transform: translateY(-5px);
        }

        .combo-name {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0 0 10px 0;
            color: var(--texto-marrom);
            line-height: 1.3;
        }

        .combo-desc-wrapper {
            display: flex;
            align-items: flex-start;
            gap: 16px; /* Espaço um pouco maior para acomodar os novos ícones */
            margin: 0 0 20px 0;
            flex-grow: 1;
        }

        .combo-icon {
            flex-shrink: 0;
            width: 48px; /* Ícones maiores e mais expressivos */
            height: 48px;
            color: var(--preco-novo-laranja);
            stroke-width: 1.8;
            margin-top: -2px; 
        }

        .combo-desc {
            font-size: 0.95rem;
            font-weight: 400;
            margin: 0;
            line-height: 1.5;
            color: var(--texto-marrom);
        }

        .price-section {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            margin-top: auto;
        }

        .old-price {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--preco-antigo-turquesa);
            text-decoration: line-through;
            margin-bottom: 4px;
        }

        /* O selo de desconto seguindo exatamente a dica extra */
        .new-price-tag {
            background-color: var(--detalhes-amarelo);
            padding: 8px 16px;
            border-radius: 12px;
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 2px dashed var(--texto-marrom);
        }

        .new-price-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--texto-marrom);
            margin-bottom: 2px;
        }

        .new-price-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--preco-novo-laranja);
            /* Pequena sombra para garantir o contraste perfeito no fundo amarelo */
            text-shadow: 1px 1px 0px rgba(255,255,255,0.4);
        }

        /* Responsividade */
        @media (max-width: 600px) {
            .menu-container {
                padding: 20px 15px;
                border-width: 4px;
            }
            .combos-grid {
                grid-template-columns: 1fr;
            }
        }

        /* --- NOVOS ESTILOS: INTERATIVIDADE E MODAL WHATSAPP --- */
        
        /* Indicador de clique no card */
        .combo-card {
            cursor: pointer;
            position: relative;
        }
        
        /* Tooltip flutuante avisando para clicar */
        .combo-card::after {
            content: '👉 Faça seu pedido!';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--preco-novo-laranja);
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            opacity: 0;
            transition: opacity 0.2s, bottom 0.2s;
            pointer-events: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .combo-card:hover::after {
            opacity: 1;
            bottom: -10px;
        }

        /* Estilos do fundo escuro do Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(122, 74, 46, 0.7); /* Marrom da paleta com transparência */
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
            backdrop-filter: blur(4px);
        }
        
        .modal-overlay.active {
            display: flex;
        }
        
        /* Estilos da caixinha do Modal */
        .modal-box {
            background: var(--fundo-creme);
            border: 4px solid var(--detalhes-amarelo);
            border-radius: 16px;
            padding: 30px;
            width: 100%;
            max-width: 400px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            position: relative;
            animation: popUp 0.3s ease-out;
        }

        @keyframes popUp {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .modal-title {
            margin-top: 0;
            color: var(--texto-marrom);
            font-size: 1.6rem;
            font-weight: 800;
        }
        
        .modal-subtitle {
            color: var(--texto-marrom);
            font-size: 1rem;
            margin-bottom: 20px;
        }
        
        .modal-input {
            width: 100%;
            padding: 14px;
            border: 2px solid var(--preco-antigo-turquesa);
            border-radius: 8px;
            margin: 10px 0 24px;
            font-family: 'Montserrat', sans-serif;
            font-size: 1.1rem;
            color: var(--texto-marrom);
            box-sizing: border-box;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        
        .modal-input:focus {
            outline: none;
            border-color: var(--preco-novo-laranja);
            box-shadow: 0 0 0 4px rgba(255, 122, 90, 0.15);
        }
        
        .modal-buttons {
            display: flex;
            gap: 12px;
            justify-content: center;
        }
        
        .btn {
            padding: 14px 20px;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            font-family: 'Montserrat', sans-serif;
            transition: all 0.2s;
            flex: 1;
        }
        
        .btn:hover {
            transform: translateY(-2px);
        }
        
        .btn-cancel {
            background: transparent;
            color: var(--texto-marrom);
            border: 2px solid var(--texto-marrom);
        }
        
        .btn-confirm {
            background: var(--preco-novo-laranja);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 10px rgba(255, 122, 90, 0.3);
        }

    </style>
</head>
<body>


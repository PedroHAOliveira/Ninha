    <!-- MODAL DE PEDIDO -->
    <div class="modal-overlay" id="orderModal">
        <div class="modal-box">
            <h3 class="modal-title">Falta pouco!</h3>
            <p class="modal-subtitle">Como podemos te chamar?</p>
            <input type="text" id="customerName" class="modal-input" placeholder="Digite seu nome..." autocomplete="name">
            <div class="modal-buttons">
                <button class="btn btn-cancel" onclick="closeModal()">Cancelar</button>
                <button class="btn btn-confirm" id="confirmOrderBtn">
                    <!-- Ícone do WhatsApp -->
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                    </svg>
                    Pedir agora
                </button>
            </div>
        </div>
    </div>

    <!-- SCRIPT DE INTERATIVIDADE -->
    <script>
        const modal = document.getElementById('orderModal');
        const nameInput = document.getElementById('customerName');
        const confirmBtn = document.getElementById('confirmOrderBtn');
        let selectedCombo = '';

        // 1. Torna os cards clicáveis e guarda qual combo foi escolhido
        document.querySelectorAll('.combo-card').forEach(card => {
            card.addEventListener('click', () => {
                selectedCombo = card.querySelector('.combo-name').innerText;
                modal.classList.add('active'); // Abre o modal
                
                // Reseta e foca no input de nome
                nameInput.value = '';
                nameInput.style.borderColor = 'var(--preco-antigo-turquesa)';
                nameInput.placeholder = 'Digite seu nome...';
                nameInput.focus();
            });
        });

        // 2. Função para fechar o modal
        function closeModal() {
            modal.classList.remove('active');
        }

        // Fecha se clicar fora da caixinha do modal
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });

        // 3. Processar o pedido e direcionar pro zap
        confirmBtn.addEventListener('click', () => {
            const customerName = nameInput.value.trim();
            
            // Validação simples se esqueceu o nome
            if (!customerName) {
                nameInput.style.borderColor = 'red';
                nameInput.placeholder = 'Por favor, me diga seu nome! 😊';
                return;
            }
            
            // Variáveis do Zap
            const phoneNumber = '5522988196364';
            // Os asteriscos deixam o nome do combo em negrito no WhatsApp
            const message = `Olá! Meu nome é ${customerName} e eu gostaria de pedir o *${selectedCombo}*.`;
            
            // Codifica a URL e abre a nova aba
            const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
            window.open(whatsappUrl, '_blank');
            
            closeModal(); // fecha a telinha depois de enviar
        });

        // 4. Facilidade: Permitir apertar "Enter" no teclado para confirmar
        nameInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                confirmBtn.click();
            }
        });
    </script>
</body>
</html>

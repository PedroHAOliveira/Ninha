                    </div>
                </div>
                <div class="price-section">
                    <span class="old-price">De: R$ 25,00</span>
                    <div class="new-price-tag">
                        <span class="new-price-label">Preço do Combo</span>
                        <span class="new-price-value">R$ 19,90</span>
                    </div>
                </div>
            </div>

            <div class="combo-card">
